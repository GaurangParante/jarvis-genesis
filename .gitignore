# ==============================================================================
# JARVIS GENESIS - CUSTOM .GITIGNORE
# ==============================================================================

# --- Python Core & Virtual Environments ---
__pycache__/
*.py[cod]
*$py.class
.env
.venv/
env/
venv/
ENV/

# --- Project Specific Runtime Data (Local Dynamic Media) ---
app/data/captures/*
app/data/recordings/*
app/data/screenshots/*
app/data/temp/*
data/screenshots/*

# Exclude keeping the folders but ignore their contents (Optional .gitkeep trick)
!app/data/captures/.gitkeep
!app/data/recordings/.gitkeep
!app/data/screenshots/.gitkeep
!app/data/temp/.gitkeep

# --- Memory & Router Cache (Local State Data) ---
app/memory/cache.json
app/memory/plan_cache.json
.pytest_cache/
.cache/

# --- Vectorstore & Embeddings Local Indexing ---
app/vectorstore/agent_vectors.json
# Agar aap metadata schema template track rakhna chahte hain to use exclude kar sakte hain:
# !app/vectorstore/metadata.json

# --- IDEs, Code Editors & OS Specific Files ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store